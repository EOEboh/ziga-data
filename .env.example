# --- Required ---
# Claude API key (https://platform.claude.com) — used for text + image extraction
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Sheets (omit both to run in dry-run mode: extraction works, rows are logged not written) ---
# Path to the service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
# The spreadsheet ID from the sheet URL: https://docs.google.com/spreadsheets/d/<SHEET_ID>/edit
SHEET_ID=
# Tab (worksheet) name to append rows to
SHEET_TAB=Leads

# --- Optional (defaults shown) ---
# LLM_MODEL=claude-haiku-4-5
# PORT=8080
# DB_PATH=./sheetdrop.db
# SCHEMA_PATH=config/schema.json
# RATE_LIMIT_PER_MIN=10
