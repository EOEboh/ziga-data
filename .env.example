# --- Required ---
# OpenAI API key (https://platform.openai.com) — used for text + image extraction
OPENAI_API_KEY=sk-...

# --- Auth / sessions ---
# Public origin of the app; used to build email links and to mark cookies Secure
# over https. Defaults to http://localhost:8080.
APP_BASE_URL=http://localhost:8080
# HMAC key for CSRF tokens. Set a long random value in production; if empty an
# ephemeral one is generated (sessions/CSRF won't survive a restart).
SESSION_SECRET=

# --- Google OAuth (identity + per-user Google Sheets, drive.file scope) ---
# From a Google Cloud OAuth 2.0 Client (Web application). Leave the client
# id/secret empty to run without Google sign-in / per-user Sheets (dev mode).
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
# Defaults to $APP_BASE_URL/api/auth/google/callback — must match the console.
OAUTH_REDIRECT_URL=
# Browser API key for the Google Picker (attach-an-existing-sheet flow).
GOOGLE_PICKER_API_KEY=
# Base64-encoded 32-byte key that encrypts OAuth tokens at rest (AES-256-GCM).
# REQUIRED whenever Google OAuth is configured. Generate one with:
#   head -c 32 /dev/urandom | base64
TOKEN_ENCRYPTION_KEY=

# --- Email (verification + password reset) ---
# Leave SMTP_HOST empty in dev to log links instead of sending them.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=ziga@localhost

# --- Sheet layout (production) ---
# Tab name used when the app creates a user's spreadsheet. Sheets attached via
# the Google Picker keep their own first tab instead.
SHEET_TAB=Leads

# --- Dev / test only: single-tenant service-account Sheets writer ---
# These drive the legacy shared-sheet writer for local dev and tests ONLY. In
# production each user connects their own sheet via Google OAuth above; these
# are ignored once GOOGLE_OAUTH_CLIENT_ID is set.
GOOGLE_APPLICATION_CREDENTIALS=./service-account.json
SHEET_ID=

# --- Optional (defaults shown) ---
# LLM_MODEL=gpt-5.4-nano
# PORT=8080
# DB_PATH=./ziga.db
# SCHEMA_PATH=config/schema.json
# RATE_LIMIT_PER_MIN=10
# RETENTION_DAYS=14
# HEADER_ROW=1
